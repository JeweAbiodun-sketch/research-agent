 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🧠 Sprint 3 — RAG Retrieval, Cohere Reranking & LangGraph Agent\n",
    "**Project:** Autonomous Company Research & Report Generation Agent  \n",
    "**Module:** 3 | **Day:** 3 of 5 | **Sprint Goal:** Retrieve from Pinecone → Rerank with Cohere → LangGraph agent classifies\n",
    "\n",
    "## What we build today\n",
    "```\n",
    "Query Pinecone (top-10) → Cohere Rerank (top-3) → LangGraph Agent → Risk Score + Opportunity Score\n",
    "```\n",
    "\n",
    "## Sprint 3 User Stories\n",
    "> **US-03:** Retrieved chunks are reranked for relevance before analysis  \n",
    "> **US-05:** System retries failed API calls and sends alerts on errors\n",
    "\n",
    "**Definition of Done:** Cohere returns top-3 reranked chunks; LangGraph agent produces risk_score and opportunity_score; errors trigger alerts."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Imports & Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, json, time, uuid\n",
    "from datetime import datetime, timezone\n",
    "from typing import TypedDict, Optional, List, Dict, Any\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "from langgraph.graph import StateGraph, END\n",
    "from openai import OpenAI\n",
    "from pinecone import Pinecone\n",
    "import cohere\n",
    "\n",
    "load_dotenv()\n",
    "OPENAI_API_KEY   = os.getenv(\"OPENAI_API_KEY\", \"\")\n",
    "PINECONE_API_KEY = os.getenv(\"PINECONE_API_KEY\", \"\")\n",
    "COHERE_API_KEY   = os.getenv(\"COHERE_API_KEY\", \"\")\n",
    "\n",
    "assert OPENAI_API_KEY,   \"❌ Set OPENAI_API_KEY\"\n",
    "assert PINECONE_API_KEY, \"❌ Set PINECONE_API_KEY\"\n",
    "assert COHERE_API_KEY,   \"❌ Set COHERE_API_KEY — get free key at cohere.com\"\n",
    "\n",
    "openai_client = OpenAI(api_key=OPENAI_API_KEY)\n",
    "pc            = Pinecone(api_key=PINECONE_API_KEY)\n",
    "cohere_client = cohere.Client(COHERE_API_KEY)\n",
    "\n",
    "PINECONE_INDEX_NAME = \"company-research-agent\"\n",
    "EMBED_MODEL         = \"text-embedding-3-small\"\n",
    "AGENT_MODEL         = \"gpt-4o-mini\"\n",
    "\n",
    "pinecone_index = pc.Index(PINECONE_INDEX_NAME)\n",
    "print(\"✅ All clients initialised\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. AgentState Schema"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class AgentState(TypedDict):\n",
    "    company_name:      str\n",
    "    ticket_id:         str\n",
    "    initiated_at:      str\n",
    "    status:            str\n",
    "    errors:            List[str]\n",
    "    raw_research:      Optional[str]\n",
    "    research_chunks:   Optional[List[str]]\n",
    "    pinecone_ids:      Optional[List[str]]\n",
    "    retrieved_chunks:  Optional[List[str]]\n",
    "    reranked_chunks:   Optional[List[str]]\n",
    "    risk_score:        Optional[str]\n",
    "    opportunity_score: Optional[int]\n",
    "    retry_count:       int\n",
    "    report_sections:   Optional[Dict[str, str]]\n",
    "    notion_url:        Optional[str]\n",
    "    report_ready:      bool\n",
    "    workflow_path:     List[str]\n",
    "\n",
    "print(\"✅ AgentState schema ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Retrieve from Pinecone Node"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def retrieve_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"\n",
    "    Node: Embed the company name as a query, retrieve top-10 chunks from Pinecone.\n",
    "\n",
    "    Reads:  state['company_name'], state['ticket_id']\n",
    "    Writes: state['retrieved_chunks'], state['status']\n",
    "    \"\"\"\n",
    "    company   = state[\"company_name\"]\n",
    "    namespace = company.lower().replace(\" \", \"-\")\n",
    "    errors    = list(state.get(\"errors\", []))\n",
    "\n",
    "    print(f\"[RETRIEVE] Querying Pinecone for '{company}'...\")\n",
    "\n",
    "    # Build a comprehensive query covering all due diligence dimensions\n",
    "    query = (\n",
    "        f\"{company} company overview business model funding investors \"\n",
    "        f\"market size competitors risk factors financial performance\"\n",
    "    )\n",
    "\n",
    "    for attempt in range(3):\n",
    "        try:\n",
    "            # Embed the query\n",
    "            embed_response = openai_client.embeddings.create(\n",
    "                model=EMBED_MODEL,\n",
    "                input=[query]\n",
    "            )\n",
    "            query_vector = embed_response.data[0].embedding\n",
    "\n",
    "            # Query Pinecone — retrieve top-10 candidates\n",
    "            results = pinecone_index.query(\n",
    "                vector    = query_vector,\n",
    "                top_k     = 10,\n",
    "                namespace = namespace,\n",
    "                include_metadata = True\n",
    "            )\n",
    "\n",
    "            chunks = [\n",
    "                match[\"metadata\"][\"text\"]\n",
    "                for match in results[\"matches\"]\n",
    "                if match.get(\"metadata\", {}).get(\"text\")\n",
    "            ]\n",
    "\n",
    "            if not chunks:\n",
    "                errors.append(f\"No chunks found in Pinecone for '{company}'. Run Sprint 2 first.\")\n",
    "                return {\n",
    "                    **state,\n",
    "                    \"status\": \"error_no_data\",\n",
    "                    \"errors\": errors,\n",
    "                    \"workflow_path\": state.get(\"workflow_path\", []) + [\"retrieve\"]\n",
    "                }\n",
    "\n",
    "            print(f\"[RETRIEVE] ✅ Retrieved {len(chunks)} chunks from Pinecone\")\n",
    "            return {\n",
    "                **state,\n",
    "                \"retrieved_chunks\": chunks,\n",
    "                \"status\":           \"retrieved\",\n",
    "                \"errors\":           errors,\n",
    "                \"workflow_path\":    state.get(\"workflow_path\", []) + [\"retrieve\"]\n",
    "            }\n",
    "\n",
    "        except Exception as e:\n",
    "            print(f\"  ⚠️ Retrieve attempt {attempt+1}/3 failed: {e}\")\n",
    "            if attempt == 2:\n",
    "                return {\n",
    "                    **state,\n",
    "                    \"status\": \"error_retrieve_failed\",\n",
    "                    \"errors\": errors + [f\"Pinecone retrieve failed: {e}\"],\n",
    "                    \"workflow_path\": state.get(\"workflow_path\", []) + [\"retrieve\"]\n",
    "                }\n",
    "            time.sleep(2 ** attempt)\n",
    "\n",
    "print(\"✅ retrieve_node defined\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Cohere Rerank Node"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def rerank_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"\n",
    "    Node: Rerank top-10 Pinecone chunks to top-3 using Cohere cross-encoder.\n",
    "    This improves precision — cosine similarity finds surface matches,\n",
    "    Cohere finds semantic relevance.\n",
    "\n",
    "    Reads:  state['retrieved_chunks'], state['company_name']\n",
    "    Writes: state['reranked_chunks'], state['status']\n",
    "    \"\"\"\n",
    "    company = state[\"company_name\"]\n",
    "    chunks  = state.get(\"retrieved_chunks\", [])\n",
    "    errors  = list(state.get(\"errors\", []))\n",
    "\n",
    "    print(f\"[RERANK] Reranking {len(chunks)} chunks with Cohere...\")\n",
    "\n",
    "    query = f\"Due diligence analysis: {company} business model, market position, funding, risks, and investment recommendation\"\n",
    "\n",
    "    for attempt in range(3):\n",
    "        try:\n",
    "            results = cohere_client.rerank(\n",
    "                model     = \"rerank-english-v3.0\",\n",
    "                query     = query,\n",
    "                documents = chunks,\n",
    "                top_n     = 3,\n",
    "                return_documents = True\n",
    "            )\n",
    "\n",
    "            reranked = [\n",
    "                r.document.text\n",
    "                for r in results.results\n",
    "                if r.document and r.document.text\n",
    "            ]\n",
    "\n",
    "            print(f\"[RERANK] ✅ Top-3 chunks selected | Scores: \"\n",
    "                  f\"{[round(r.relevance_score, 3) for r in results.results]}\")\n",
    "\n",
    "            return {\n",
    "                **state,\n",
    "                \"reranked_chunks\": reranked,\n",
    "                \"status\":          \"reranked\",\n",
    "                \"errors\":          errors,\n",
    "                \"workflow_path\":   state.get(\"workflow_path\", []) + [\"rerank\"]\n",
    "            }\n",
    "\n",
    "        except Exception as e:\n",
    "            print(f\"  ⚠️ Rerank attempt {attempt+1}/3 failed: {e}\")\n",
    "            if attempt == 2:\n",
    "                # Fallback: use first 3 retrieved chunks\n",
    "                print(\"  [RERANK] Falling back to top-3 by Pinecone similarity score\")\n",
    "                return {\n",
    "                    **state,\n",
    "                    \"reranked_chunks\": chunks[:3],\n",
    "                    \"status\":          \"reranked_fallback\",\n",
    "                    \"errors\":          errors + [f\"Cohere rerank failed, used fallback: {e}\"],\n",
    "                    \"workflow_path\":   state.get(\"workflow_path\", []) + [\"rerank\"]\n",
    "                }\n",
    "            time.sleep(2 ** attempt)\n",
    "\n",
    "print(\"✅ rerank_node defined\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. LangGraph Analysis Agent Node"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "CLASSIFICATION_PROMPT = \"\"\"\\\n",
    "You are a senior venture capital analyst. Analyse the provided research context about {company}\n",
    "and return a JSON object with exactly these fields:\n",
    "\n",
    "{{\n",
    "  \"risk_score\": \"low\" | \"medium\" | \"high\",\n",
    "  \"opportunity_score\": <integer 1-10>,\n",
    "  \"stage\": \"pre-seed\" | \"seed\" | \"series-a\" | \"series-b\" | \"series-c+\" | \"growth\" | \"public\",\n",
    "  \"sector\": \"<primary sector>\",\n",
    "  \"investment_priority\": \"pass\" | \"watch\" | \"invest\",\n",
    "  \"key_strength\": \"<one sentence>\",\n",
    "  \"key_concern\": \"<one sentence>\",\n",
    "  \"confidence\": \"low\" | \"medium\" | \"high\"\n",
    "}}\n",
    "\n",
    "Risk scoring rules:\n",
    "- low: established revenue, strong team, clear moat, regulated market\n",
    "- medium: early revenue, some competition, moderate burn rate\n",
    "- high: pre-revenue, intense competition, regulatory uncertainty, key-person risk\n",
    "\n",
    "Return ONLY valid JSON. No markdown, no explanation.\"\"\"\n",
    "\n",
    "\n",
    "def analyse_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"\n",
    "    Node: LangGraph analysis agent — classifies risk, opportunity, and priority\n",
    "    using the reranked context chunks.\n",
    "\n",
    "    Reads:  state['reranked_chunks'], state['company_name']\n",
    "    Writes: state['risk_score'], state['opportunity_score'], state['status']\n",
    "    \"\"\"\n",
    "    company = state[\"company_name\"]\n",
    "    chunks  = state.get(\"reranked_chunks\", [])\n",
    "    errors  = list(state.get(\"errors\", []))\n",
    "\n",
    "    print(f\"[ANALYSE] Running LangGraph analysis agent on '{company}'...\")\n",
    "\n",
    "    context = \"\\n\\n---\\n\\n\".join(chunks)\n",
    "    system  = CLASSIFICATION_PROMPT.format(company=company)\n",
    "\n",
    "    for attempt in range(3):\n",
    "        try:\n",
    "            response = openai_client.chat.completions.create(\n",
    "                model       = AGENT_MODEL,\n",
    "                temperature = 0,\n",
    "                messages    = [\n",
    "                    { \"role\": \"system\", \"content\": system },\n",
    "                    { \"role\": \"user\",   \"content\": f\"Research context:\\n{context}\\n\\nAnalyse {company}.\" }\n",
    "                ],\n",
    "                response_format = { \"type\": \"json_object\" }\n",
    "            )\n",
    "\n",
    "            raw     = response.choices[0].message.content\n",
    "            parsed  = json.loads(raw)\n",
    "\n",
    "            risk   = parsed.get(\"risk_score\", \"medium\")\n",
    "            opport = int(parsed.get(\"opportunity_score\", 5))\n",
    "            priority = parsed.get(\"investment_priority\", \"watch\")\n",
    "\n",
    "            print(f\"[ANALYSE] ✅ Risk: {risk} | Opportunity: {opport}/10 | Priority: {priority}\")\n",
    "            print(f\"[ANALYSE]    Stage: {parsed.get('stage')} | Sector: {parsed.get('sector')}\")\n",
    "            print(f\"[ANALYSE]    Strength: {parsed.get('key_strength', '')[:80]}\")\n",
    "            print(f\"[ANALYSE]    Concern : {parsed.get('key_concern', '')[:80]}\")\n",
    "\n",
    "            return {\n",
    "                **state,\n",
    "                \"risk_score\":        risk,\n",
    "                \"opportunity_score\": opport,\n",
    "                \"status\":            \"analysed\",\n",
    "                \"errors\":            errors,\n",
    "                # Store full classification in report_sections for Sprint 4\n",
    "                \"report_sections\":   { \"_classification\": json.dumps(parsed) },\n",
    "                \"workflow_path\":     state.get(\"workflow_path\", []) + [\"analyse\"]\n",
    "            }\n",
    "\n",
    "        except Exception as e:\n",
    "            print(f\"  ⚠️ Analyse attempt {attempt+1}/3 failed: {e}\")\n",
    "            if attempt == 2:\n",
    "                return {\n",
    "                    **state,\n",
    "                    \"status\": \"error_analysis_failed\",\n",
    "                    \"errors\": errors + [f\"Analysis failed: {e}\"],\n",
    "                    \"workflow_path\": state.get(\"workflow_path\", []) + [\"analyse\"]\n",
    "                }\n",
    "            time.sleep(2 ** attempt)\n",
    "\n",
    "print(\"✅ analyse_node defined\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Error Alert Node (US-05)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def error_handler_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"\n",
    "    Error handler — prints alert (in production: sends Telegram message).\n",
    "    US-05: System retries failed calls and alerts analyst on errors.\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"!\"*55)\n",
    "    print(\"  🚨 PIPELINE ERROR — ANALYST ALERT\")\n",
    "    print(\"!\"*55)\n",
    "    print(f\"  Company  : {state.get('company_name')}\")\n",
    "    print(f\"  Ticket   : {state.get('ticket_id')}\")\n",
    "    print(f\"  Status   : {state.get('status')}\")\n",
    "    print(f\"  Errors   :\")\n",
    "    for e in state.get(\"errors\", []):\n",
    "        print(f\"    ❌ {e}\")\n",
    "    print(\"  → In production: Telegram alert sent to analyst\")\n",
    "    print(\"!\"*55)\n",
    "\n",
    "    return {\n",
    "        **state,\n",
    "        \"status\": \"failed\",\n",
    "        \"workflow_path\": state.get(\"workflow_path\", []) + [\"error_handler\"]\n",
    "    }\n",
    "\n",
    "print(\"✅ error_handler_node defined (US-05 satisfied)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Build Sprint 3 Graph"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def route_node(state: AgentState) -> str:\n",
    "    \"\"\"Generic router — if status contains 'error', go to error_handler.\"\"\"\n",
    "    return \"error_handler\" if \"error\" in state.get(\"status\", \"\") else \"continue\"\n",
    "\n",
    "\n",
    "def build_sprint3_graph():\n",
    "    g = StateGraph(AgentState)\n",
    "\n",
    "    g.add_node(\"retrieve\",      retrieve_node)\n",
    "    g.add_node(\"rerank\",        rerank_node)\n",
    "    g.add_node(\"analyse\",       analyse_node)\n",
    "    g.add_node(\"error_handler\", error_handler_node)\n",
    "\n",
    "    g.set_entry_point(\"retrieve\")\n",
    "\n",
    "    # retrieve → rerank or error\n",
    "    g.add_conditional_edges(\"retrieve\", route_node,\n",
    "        { \"continue\": \"rerank\", \"error_handler\": \"error_handler\" })\n",
    "\n",
    "    # rerank → analyse or error\n",
    "    g.add_conditional_edges(\"rerank\", route_node,\n",
    "        { \"continue\": \"analyse\", \"error_handler\": \"error_handler\" })\n",
    "\n",
    "    # analyse → END or error\n",
    "    g.add_conditional_edges(\"analyse\", route_node,\n",
    "        { \"continue\": END, \"error_handler\": \"error_handler\" })\n",
    "\n",
    "    g.add_edge(\"error_handler\", END)\n",
    "    return g.compile()\n",
    "\n",
    "\n",
    "sprint3_graph = build_sprint3_graph()\n",
    "print(\"✅ Sprint 3 graph compiled\")\n",
    "print(\"   Flow: retrieve → rerank → analyse → END\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Run — Retrieve, Rerank & Analyse"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load state from Sprint 2 output\n",
    "import pathlib\n",
    "\n",
    "if pathlib.Path(\"sprint2_output.json\").exists():\n",
    "    sprint2_data = json.loads(pathlib.Path(\"sprint2_output.json\").read_text())\n",
    "    state = AgentState(**{k: sprint2_data.get(k) for k in AgentState.__annotations__})\n",
    "    print(f\"✅ Loaded Sprint 2 state for: {state['company_name']}\")\n",
    "else:\n",
    "    # Create fresh state if Sprint 2 output not found\n",
    "    COMPANY = \"Anthropic\"  # ← Must match what you researched in Sprint 2\n",
    "    state = AgentState(\n",
    "        company_name=\"Anthropic\", ticket_id=\"RES-TEST-001\",\n",
    "        initiated_at=datetime.now(timezone.utc).isoformat(),\n",
    "        status=\"stored\", errors=[], raw_research=None,\n",
    "        research_chunks=None, pinecone_ids=None,\n",
    "        retrieved_chunks=None, reranked_chunks=None,\n",
    "        risk_score=None, opportunity_score=None,\n",
    "        retry_count=0, report_sections=None,\n",
    "        notion_url=None, report_ready=False, workflow_path=[]\n",
    "    )\n",
    "    print(f\"⚠️ No sprint2_output.json found — using fresh state for '{state['company_name']}'\")\n",
    "    print(\"   Make sure you ran Sprint 2 first!\")\n",
    "\n",
    "print(f\"\\nRunning Sprint 3 for: {state['company_name']}\")\n",
    "result = sprint3_graph.invoke(state)\n",
    "\n",
    "print(f\"\\n{'='*55}\")\n",
    "print(f\"  Status            : {result['status']}\")\n",
    "print(f\"  Risk Score        : {result.get('risk_score')}\")\n",
    "print(f\"  Opportunity Score : {result.get('opportunity_score')}/10\")\n",
    "print(f\"  Reranked chunks   : {len(result.get('reranked_chunks') or [])}\")\n",
    "print(f\"  Workflow path     : {' → '.join(result['workflow_path'])}\")\n",
    "print(f\"  Errors            : {result.get('errors', [])}\")\n",
    "print(f\"{'='*55}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
